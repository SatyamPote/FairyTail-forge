generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id              String   @id @default(uuid())
  title           String
  genre           String
  numPanels       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  panels          Panel[]
  characters      Character[]
}

model Panel {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  panelNumber     Int
  prompt          String
  negativePrompt  String?
  content         String?  // The script content for this panel
  narration       String?
  dialogue        String?
  imagePath       String?
  status          String   @default("pending") // pending, generating, completed, failed
  createdAt       DateTime @default(now())
}

model Character {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  description     String
  appearance      String
  imageUrl        String?
  createdAt       DateTime @default(now())
}
